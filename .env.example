# Copy to .env and adjust for your local setup.
# All values shown here match the dev defaults baked into settings.py —
# you only need to override what differs in your environment.

# Server
HOST=0.0.0.0
PORT=8015

# Database (asyncpg driver for runtime, plain psycopg2 for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:securepassword123@host.docker.internal:15432/grid
DATABASE_ECHO=false

# JWT header injected by oauth2-proxy
JWT_HEADER_NAME=x-auth-request-access-token

# OIDC — token verification (inbound) + client-credentials (outbound service calls)
CELINE_OIDC_BASE_URL=http://keycloak.celine.localhost/realms/celine
CELINE_OIDC_JWKS_URI=http://keycloak.celine.localhost/realms/celine/protocol/openid-connect/certs
CELINE_OIDC_AUDIENCE=svc-grid
CELINE_OIDC_CLIENT_ID=svc-grid
CELINE_OIDC_CLIENT_SECRET=svc-grid  # override in production

# CORS — add the grid UI origin
CORS_ORIGINS=["http://localhost:3006"]

# Upstream services
DIGITAL_TWIN_API_URL=http://host.docker.internal:8002
NUDGING_API_URL=http://host.docker.internal:8016

# MQTT broker (pipeline run events)
CELINE_MQTT_HOST=host.docker.internal
CELINE_MQTT_PORT=1883
# CELINE_MQTT_USERNAME=
# CELINE_MQTT_PASSWORD=

# Grid pipeline flow name (must match the DT pipeline that publishes resilience results)
GRID_PIPELINE_FLOW=grid-resilience-flow
