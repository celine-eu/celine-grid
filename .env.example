# Copy to .env and adjust for your local setup

# Server
HOST=0.0.0.0
PORT=8015

# Database (asyncpg driver for runtime, plain psycopg2 for alembic)
DATABASE_URL=postgresql+asyncpg://postgres:securepassword123@host.docker.internal:15432/celine_grid
DATABASE_ECHO=false

# JWT header injected by oauth2-proxy
JWT_HEADER_NAME=x-auth-request-access-token

# OIDC (used for token verification)
OIDC__BASE_URL=https://keycloak.celine.localhost/realms/celine
OIDC__CLIENT_ID=celine-grid
OIDC__VERIFY_SSL=false

# Upstream services
DIGITAL_TWIN_API_URL=http://host.docker.internal:8002

# Default DT network / entity ID used when the frontend doesn't pass one
DEFAULT_NETWORK_ID=default

# CORS — add the grid UI origin
CORS_ORIGINS=["http://localhost:3006"]
